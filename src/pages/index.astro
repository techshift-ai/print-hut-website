---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero';
import Products from '../components/sections/Products';
import WhyPrintHut from '../components/sections/WhyPrintHut';
import Gallery from '../components/sections/Gallery';
import FAQ from '../components/sections/FAQ';
import Contact from '../components/sections/Contact';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What does Print Hut print?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Print Hut prints custom t-shirts, hoodies, business cards, flyers, table cloths, stickers, and decals. Whether you need 50 t-shirts for a team event or 5,000 flyers for a promotion, we handle it.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long does printing take?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Standard orders are ready in a few business days. Rush jobs available — call 647.780.3103 or visit 260 Regina Road in Woodbridge.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I bring my own design?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Print Hut accepts design files for all products. If you do not have a design ready, we can help set one up.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I place an order?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Fill out the quote form on the website, call 647.780.3103, email sales@printhut.ca, or walk into the shop at 260 Regina Road in Woodbridge.',
      },
    },
    {
      '@type': 'Question',
      name: 'Where is Print Hut located?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Print Hut is at 260 Regina Road, Unit 16B, Woodbridge, Ontario, L4L 8P8, Canada.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do you handle bulk or large orders?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Print Hut handles orders of all sizes — from a single custom table cloth to thousands of flyers or hundreds of t-shirts. Contact us with your quantity for a quote.',
      },
    },
    {
      '@type': 'Question',
      name: 'What file formats do you accept?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'We accept most common design formats including PDF, AI, PSD, PNG, and JPG. Bring your file in or send it over and we will let you know if anything needs adjusting.',
      },
    },
  ],
};
---

<Layout
  title="Print Hut — Custom Printing in Woodbridge, ON | T-Shirts, Business Cards, Flyers"
  description="Print Hut is a custom printing shop in Woodbridge, Ontario. T-shirts, business cards, flyers, table cloths, stickers, and decals. Quality prints, fast turnaround, and personal service from a local shop."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Hero client:load />
  <Products client:visible />
  <WhyPrintHut client:visible />
  <Gallery client:visible />
  <FAQ client:visible />
  <Contact client:visible />
</Layout>
