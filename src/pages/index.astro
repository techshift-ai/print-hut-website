---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero';
import Products from '../components/sections/Products';
import WhyPrintHut from '../components/sections/WhyPrintHut';
import Gallery from '../components/sections/Gallery';
import FAQ from '../components/sections/FAQ';
import Contact from '../components/sections/Contact';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much do business cards cost at Print Hut?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Print Hut prints standard 3.5" x 2" business cards on quality card stock. Single-sided: 500 for $60, 1,000 for $100. Double-sided: 500 for $80, 1,000 for $120. Bring your design file or we will help set one up.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much do flyers cost at Print Hut?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Flyer pricing for 5.5" x 8.5" starts at 500 for $100, 1,000 for $200, 2,000 for $250, 3,000 for $300, and 5,000 for $350. Larger sizes available — contact us for pricing.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long does printing take?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Standard orders are ready in a few business days. Rush jobs available — call 647.780.3103 or visit 260 Regina Road in Woodbridge.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I bring my own design?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Print Hut accepts design files for all products. If you do not have a design ready, we can help set one up.',
      },
    },
    {
      '@type': 'Question',
      name: 'Where is Print Hut located?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Print Hut is at 260 Regina Road, Unit 16B, Woodbridge, Ontario, L4L 8P8, Canada.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do you print custom t-shirts and hoodies?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Custom t-shirts and hoodies for teams, events, uniforms, merch, and personal projects. Contact us for a quote.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much do custom table cloths cost?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Custom table cloths for standard 6-foot folding tables are $80 for one and $120 for two. Black and white base options available.',
      },
    },
  ],
};
---

<Layout
  title="Print Hut — Custom Printing in Woodbridge, ON | T-Shirts, Business Cards, Flyers"
  description="Print Hut is a custom printing shop in Woodbridge, Ontario. T-shirts, business cards starting at $60, flyers starting at $100, table cloths, stickers, and decals. Real prices, fast turnaround."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Hero client:load />
  <Products client:visible />
  <WhyPrintHut client:visible />
  <Gallery client:visible />
  <FAQ client:visible />
  <Contact client:visible />
</Layout>
